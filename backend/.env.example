# ══════════════════════════════════════════════════════════════════════════════
#  命盘智镜 — 环境变量模板
# ══════════════════════════════════════════════════════════════════════════════
#  复制: cp .env.example .env && nano .env
#
#  优先级: 🔴 必填  🟡 强烈推荐  ⚪ 可选
# ══════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
# 生成密钥: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=                                   # 🔴
JWT_SECRET_KEY=                               # 🔴
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","https://khanfate.com","https://www.khanfate.com"]
FRONTEND_URL=https://khanfate.com

# ── Database ─────────────────────────────────────────────────────────────────
# 推荐: Supabase (免费 500MB) 或 Neon (免费 0.5GB)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/destiny  # 🔴

# ── ChromaDB (向量数据库，可选) ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ── AI 模型 ──────────────────────────────────────────────────────────────────
# DeepSeek: https://platform.deepseek.com
OPENAI_API_KEY=                              # 🔴
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
MASTER_FAST_MODEL=deepseek-v4-flash
PREMIUM_MODEL=deepseek-v4-pro

# ── 微信支付 ─────────────────────────────────────────────────────────────────
# 申请: https://pay.weixin.qq.com
WECHAT_PAY_ENABLED=false
WECHAT_APPID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://khanfate.com/api/payments/wechat/notify

# ── 支付宝 ───────────────────────────────────────────────────────────────────
# 申请: https://open.alipay.com
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=https://khanfate.com/api/payments/alipay/notify
ALIPAY_RETURN_URL=https://khanfate.com/payment/success

# ── PayPal ───────────────────────────────────────────────────────────────────
# 申请: https://developer.paypal.com
PAYPAL_ENABLED=false
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_RETURN_URL=https://khanfate.com/payment/success
PAYPAL_CANCEL_URL=https://khanfate.com/payment/cancel

# ── 个人收款码 (简化支付) ───────────────────────────────────────────────────
ALIPAY_PERSONAL_QR_URL=
WECHAT_PERSONAL_QR_URL=
PAYPAL_PERSONAL_QR_URL=
PAYPAL_PERSONAL_EMAIL=

# ── 星尘充值 ─────────────────────────────────────────────────────────────────
AIFADIAN_URL=
USDT_TRC20_ADDRESS=
USDT_ARBITRUM_ADDRESS=
USDT_GRANT_RATE=70
PAYPAL_GRANT_RATE=70.0
TRONGRID_API_KEY=

# ── 定时任务 ─────────────────────────────────────────────────────────────────
CRON_SECRET=                                 # 🔴

# ── 管理员邮箱 (逗号分隔) ───────────────────────────────────────────────────
ADMIN_EMAILS=                                # 🟡

# ── AWS S3 (头像/图片存储，可选) ─────────────────────────────────────────────
S3_BUCKET=
S3_REGION=ap-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── 地理编码 (可选) ──────────────────────────────────────────────────────────
GEOCODING_API_KEY=

# ── SMTP 邮件 (注册验证码 & 提醒) ───────────────────────────────────────────
SMTP_HOST=smtp.qq.com                        # 🟡
SMTP_PORT=465                                # 🟡
SMTP_USER=                                   # 🟡
SMTP_PASS=                                   # 🟡
SMTP_FROM=                                   # 🟡
SMTP_FROM_NAME=命盘智镜
