{
  "name": "destiny-platform-miniprogram",
  "version": "1.0.0",
  "private": true,
  "description": "AlphaMirror 命盘智镜 — 微信小程序",
  "templateInfo": {
    "name": "default",
    "typescript": true,
    "css": "sass"
  },
  "scripts": {
    "build:weapp": "taro build --type weapp",
    "dev:weapp": "taro build --type weapp --watch",
    "build:h5": "taro build --type h5",
    "dev:h5": "taro build --type h5 --watch"
  },
  "browserslist": [
    "last 3 versions",
    "Android >= 4.1",
    "ios >= 8"
  ],
  "dependencies": {
    "@tarojs/cli": "3.6.31",
    "@tarojs/components": "3.6.31",
    "@tarojs/helper": "3.6.31",
    "@tarojs/plugin-framework-react": "3.6.31",
    "@tarojs/plugin-platform-weapp": "3.6.31",
    "@tarojs/plugin-platform-h5": "3.6.31",
    "@tarojs/react": "3.6.31",
    "@tarojs/runtime": "3.6.31",
    "@tarojs/shared": "3.6.31",
    "@tarojs/taro": "3.6.31",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.1.0",
    "tailwindcss": "^3.3.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "sass": "^1.60.0",
    "@tarojs/webpack5-runner": "3.6.31",
    "webpack": "5.88.0"
  }
}
