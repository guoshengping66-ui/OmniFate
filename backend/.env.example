# App
SECRET_KEY=your-super-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
FRONTEND_URL=https://yourdomain.com

# ICP Filing (required for China-hosted websites)
# ICP_NUMBER=你的ICP备案号

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/destiny

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# AI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── 微信支付 ──
WECHAT_PAY_ENABLED=true
WECHAT_APPID=wx1234567890abcdef
WECHAT_MCH_ID=1234567890
WECHAT_API_KEY=your-wechat-api-key
WECHAT_NOTIFY_URL=https://yourdomain.com/api/payments/wechat/notify

# ── 支付宝 ──
ALIPAY_ENABLED=true
ALIPAY_APP_ID=2021001234567890
ALIPAY_PRIVATE_KEY=MIIEvgIBADANBg...你的私钥...
ALIPAY_PUBLIC_KEY=MIIBIjANBgkqhk...支付宝公钥...
ALIPAY_NOTIFY_URL=https://yourdomain.com/api/payments/alipay/notify
ALIPAY_RETURN_URL=https://yourdomain.com/payment/success

# ── PayPal ──
PAYPAL_ENABLED=true
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox
PAYPAL_RETURN_URL=https://yourdomain.com/payment/success
PAYPAL_CANCEL_URL=https://yourdomain.com/payment/cancel

# ── 个人收款码（简化支付）──
ALIPAY_PERSONAL_QR_URL=/qrcode-alipay.png
WECHAT_PERSONAL_QR_URL=/qrcode-wechat.png
PAYPAL_PERSONAL_QR_URL=
PAYPAL_PERSONAL_EMAIL=your-paypal@email.com

# AWS S3 (face image storage)
S3_BUCKET=destiny-platform-images
S3_REGION=ap-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# Geocoding
GEOCODING_API_KEY=...

# ── SMTP 邮件配置（注册验证码 & 密码重置）──
# 推荐使用 QQ邮箱/163邮箱/Gmail/阿里云企业邮箱 等
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-authorize-code
SMTP_FROM=your-email@qq.com
SMTP_FROM_NAME=命盘智镜
