# App
SECRET_KEY=your-super-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
DEBUG=false
ALLOWED_ORIGINS=["http://localhost:3000","https://yourdomain.com"]
FRONTEND_URL=https://yourdomain.com

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/destiny

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001

# AI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PREMIUM=price_...

# Payment Methods (via Stripe) - Set to true to enable
ALIPAY_ENABLED=true
WECHAT_PAY_ENABLED=true
PAYPAL_ENABLED=true

# AWS S3 (face image storage)
S3_BUCKET=destiny-platform-images
S3_REGION=ap-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...

# Geocoding
GEOCODING_API_KEY=...